# Database (Railway Postgres or Neon)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knights_and_kings

# Redis (Railway Redis or Upstash)
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-random-secret

# OAuth Providers (optional — dev-login works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Dev mode (set to "true" for dev-login without OAuth)
NEXT_PUBLIC_DEV_AUTH=true

# Production: set this to your Railway API service URL
# NEXT_PUBLIC_API_URL=https://your-api.railway.app

# Production: set this to your Railway web service URL (used by API CORS)
# WEB_URL=https://your-web.railway.app
