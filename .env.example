DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knights_and_kings
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-random-secret

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Set to "true" to enable dev-login (local development without OAuth)
NEXT_PUBLIC_DEV_AUTH=true
