{
  "name": "knights-and-kings",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "db:up": "docker compose up -d",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:deploy": "prisma db push",
    "db:generate": "prisma generate",
    "build:web": "pnpm --filter @knights/web build",
    "build:api": "echo 'API uses tsx, no build needed'",
    "build:worker": "echo 'Worker uses tsx, no build needed'",
    "start:web": "pnpm --filter @knights/web start",
    "start:api": "pnpm --filter @knights/api start",
    "start:worker": "pnpm --filter @knights/worker start",
    "postinstall": "prisma generate",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^9.9.0",
    "prisma": "^5.19.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.58.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  }
}
