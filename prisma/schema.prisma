generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InstitutionType {
  Pawn
  Knight
  Rook
  Bishop
  Queen
  King
}

enum CardRarity {
  Common
  Uncommon
  Rare
  UltraRare
  Legendary
}

model User {
  id            String        @id @default(uuid())
  externalId    String        @unique
  displayName   String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  realms        Realm[]
  cardInstances CardInstance[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Region {
  id        String  @id @default(uuid())
  name      String
  realms    Realm[]
  createdAt DateTime @default(now())

  @@unique([name])
}

model Realm {
  id                  String             @id @default(uuid())
  name                String
  originLat           Float
  originLng           Float
  wealth              Int                @default(0)
  population          Int                @default(100)
  lastTickAt          DateTime?
  legitimacyScore     Float              @default(50)
  pillarInstitutions  Float              @default(50)
  pillarWealth        Float              @default(50)
  pillarPopulation    Float              @default(50)
  pillarCulture       Float              @default(50)
  pillarFaith         Float              @default(50)
  pillarVictory       Float              @default(0)
  pillarTime          Float              @default(0)
  isInterregnum       Boolean            @default(false)
  interregnumStartedAt DateTime?
  userId              String
  regionId            String
  dynastyId           String?
  user                User               @relation(fields: [userId], references: [id])
  region              Region             @relation(fields: [regionId], references: [id])
  institutionSlots    InstitutionSlot[]
  cardInstances       CardInstance[]
  reigns              Reign[]
  gameEvents          GameEventLog[]
  dynasties           Dynasty[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model InstitutionSlot {
  id              String           @id @default(uuid())
  realmId         String
  type            InstitutionType
  establishedAt   DateTime         @default(now())
  installedCardId String?          @unique
  installedAt     DateTime?
  termEndsAt      DateTime?
  consecutiveTerms Int             @default(0)
  realm           Realm            @relation(fields: [realmId], references: [id])
  installedCard   CardInstance?    @relation("InstalledCard", fields: [installedCardId], references: [id])

  @@unique([realmId, type])
}

model CardTemplate {
  id                String         @id @default(uuid())
  name              String         @unique
  type              InstitutionType
  rarity            CardRarity
  isLegendary       Boolean        @default(false)
  benefitPillars    Json?
  downsidePillars   Json?
  pressures         Json?
  termModifier      Float          @default(0)
  flavorText        String?
  installCostOverride Int?
  createdAt         DateTime       @default(now())
  instances         CardInstance[]
}

model CardInstance {
  id              String       @id @default(uuid())
  templateId      String
  ownerUserId     String
  realmId         String?
  template        CardTemplate @relation(fields: [templateId], references: [id])
  owner           User         @relation(fields: [ownerUserId], references: [id])
  realm           Realm?       @relation(fields: [realmId], references: [id])
  installedSlot   InstitutionSlot? @relation("InstalledCard")
  createdAt       DateTime     @default(now())
}

model Reign {
  id              String    @id @default(uuid())
  realmId         String
  kingCardId      String
  queenCardId     String?
  startedAt       DateTime  @default(now())
  endsAt          DateTime
  endedEarly      Boolean   @default(false)
  endReason       String?
  dynastyId       String?
  realm           Realm     @relation(fields: [realmId], references: [id])
  dynasty         Dynasty?  @relation(fields: [dynastyId], references: [id])
  createdAt       DateTime  @default(now())
}

model Dynasty {
  id            String    @id @default(uuid())
  realmId       String
  name          String
  foundedAt     DateTime  @default(now())
  legacyEchoes  Json?
  realm         Realm     @relation(fields: [realmId], references: [id])
  reigns        Reign[]
  heirs         Heir[]
  createdAt     DateTime  @default(now())
}

model Heir {
  id              String    @id @default(uuid())
  dynastyId       String
  name            String
  quality         String
  hiddenStats     Json
  isRevealed      Boolean   @default(false)
  isCrowned       Boolean   @default(false)
  generatedFrom   String
  dynasty         Dynasty   @relation(fields: [dynastyId], references: [id])
  createdAt       DateTime  @default(now())
}

model RaidLog {
  id                  String    @id @default(uuid())
  attackerRealmId     String
  defenderRealmId     String
  lootGained          Int       @default(0)
  attackerStabilityHit Float    @default(0)
  defenderStabilityHit Float    @default(0)
  success             Boolean   @default(false)
  occurredAt          DateTime  @default(now())
}

model ObscurityCooldown {
  id              String    @id @default(uuid())
  cardInstanceId  String
  regionId        String
  cooldownUntil   DateTime
  createdAt       DateTime  @default(now())

  @@unique([cardInstanceId, regionId])
}

model GameEventLog {
  id          String   @id @default(uuid())
  realmId     String
  eventType   String
  data        Json     @default("{}")
  occurredAt  DateTime @default(now())
  realm       Realm    @relation(fields: [realmId], references: [id])

  @@index([realmId, occurredAt])
}
